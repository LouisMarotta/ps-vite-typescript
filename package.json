{
  "name": "prestashopvite",
  "description": "PrestaShop module built with Vite and Typescript",
  "version": "0.0.1",
  "author": {
    "name": "Louis Marotta",
    "email": "loumb31@gmail.com"
  },
  "license": "MIT",
  "private": true,
  "type": "module",
  "keywords": [
    "prestashop",
    "vite",
    "typescript"
  ],
  "scripts": {
    "dev": "bun run preprocess && vite",
    "preprocess": "bun ./bin/preprocess.js",
    "build": "tsc && vite build && bun ./bin/build.js",
    "build:zip": "tsc && vite build && bun ./bin/build.js zip",
    "preview": "vite preview",
    "clean": "rimraf dist",
    "playwright:test": "bunx playwright test",
    "playwright:test:ui": "bunx playwright test --ui",
    "docker:run": "docker compose up",
    "docker:run:d": "docker compose up -d"
  },
  "devDependencies": {
    "@logtape/logtape": "^1.3.7",
    "@logtape/pretty": "^1.3.7",
    "@playwright/test": "^1.58.2",
    "@types/jquery": "^3.5.34",
    "@types/node": "^25.5.0",
    "@zip.js/zip.js": "^2.8.23",
    "browserslist": "^4.28.1",
    "dotenv": "^17.3.1",
    "es-toolkit": "^1.45.1",
    "lightningcss": "^1.32.0",
    "path": "^0.12.7",
    "rimraf": "^6.1.3",
    "simple-git": "^3.33.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-static-copy": "^3.3.0"
  },
  "dependencies": {}
}

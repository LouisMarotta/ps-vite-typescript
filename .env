# MySQL configuration
MYSQL_DATABASE=prestashop
MYSQL_USER=prestashop
MYSQL_PASSWORD=prestashop

# PS Versions to use
PS_VERSION=8.2.3
PHP_VERSION=8.1
MYSQL_VERSION=lts

PRESTASHOP_DOCKER_TAG=${PS_VERSION}-${PHP_VERSION}-fpm-bookworm-apache

GID=1000
UID=1000

# PrestaShop setup configuration data
BASE_URL=localhost:8181
PS_DB_PREFIX=ps_
PS_FOLDER_ADMIN=admin-dev
PS_ADMIN_EMAIL=admin@prestashop.com
PS_ADMIN_PASSWORD=prestashop
PS_LANGUAGE=en
PS_COUNTRY=US
PS_ENV=prod

# XDebug configuration data
XDEBUG_HOST=172.17.0.1
XDEBUG_KEY=phpstorm-xdebug

PLUGIN_VERSION=1.0.1
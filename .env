# MySQL configuration
MYSQL_DATABASE=prestashop
MYSQL_USER=prestashop
MYSQL_PASSWORD=prestashop

# PS Versions to use
PS_VERSION=8.1
PHP_VERSION=7.4
MYSQL_VERSION=8.1

PRESTASHOP_DOCKER_TAG=${PS_VERSION}-${PHP_VERSION}-apache

GID=1000

# PrestaShop setup configuration data
BASE_URL=localhost:8181
PS_DB_PREFIX=ps_
PS_FOLDER_ADMIN=ps_admin
PS_ADMIN_EMAIL=admin@demo.com
PS_ADMIN_PASSWORD=admin123
PS_LANGUAGE=en
PS_COUNTRY=US
PS_ENV=prod

# XDebug configuration data
XDEBUG_HOST=172.17.0.1
XDEBUG_KEY=phpstorm-xdebug

PLUGIN_VERSION=1.0.1